{
  "manifest_version": 3,
  "name": "Auto Translator for Discord",
  "version": "1.0.0",
  "description": "Auto-translates Discord messages to English in real time, including new incoming messages. By HYAIPE — open source on GitHub.",
  "author": { "email": "hyaipe.io@gmail.com" },
  "homepage_url": "https://github.com/HYAIPE/DiscordTranslator",
  "minimum_chrome_version": "100",
  "permissions": ["storage"],
  "host_permissions": ["https://translate.googleapis.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://discord.com/*", "https://*.discord.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Toggle Discord auto-translation",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
